# Supabase project URL (public — safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (public — safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — KEEP SECRET, server-side only
# Never expose this to the browser or commit it to source control
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# HMAC secret used to sign DP3 license keys — KEEP SECRET, server-side only
# Must match the secret configured in the DentalPro desktop application
# Generate with: openssl rand -hex 32
LICENSE_HMAC_SECRET=your-hmac-secret-here

# Comma-separated list of admin email addresses allowed to access the dashboard
# Example: admin@example.com,another-admin@example.com
ADMIN_EMAIL_WHITELIST=admin@example.com
